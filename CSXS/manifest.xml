<?xml version='1.0' encoding='UTF-8'?>
<ExtensionManifest ExtensionBundleId="com.invaiz.extension" ExtensionBundleVersion="1.0.0" Version="6.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.invaiz.extension.panel" Version="1.0.0" />
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="PHSP" Version="19.0" />
      <Host Name="PHXS" Version="19.0" />
     	<Host Name="ILST" Version="19.0"/>
      <Host Name="AEFT" Version="15.0"/>
      <Host Name="IDSN" Version="16.0"/>
      <Host Name="PPRO" Version="11.0"/>
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="6.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.invaiz.extension.panel">
        <DispatchInfo Host="PHSP">
            <Lifecycle>
                <AutoVisible>false</AutoVisible>
                  <StartOn>
                      <Event>com.adobe.csxs.events.AppOnline</Event>
                  </StartOn>
            </Lifecycle>
            <UI>
          <Type>Custom</Type>
           <Menu>INVAIZ Extension</Menu>
            </UI>
            </DispatchInfo>

        <DispatchInfo Host="PHXS">
              <Lifecycle>
                  <AutoVisible>false</AutoVisible>
                    <StartOn>
                      <Event>com.adobe.csxs.events.AppOnline</Event>
                    </StartOn>
              </Lifecycle>
              <UI>
                <Type>Custom</Type>
                  <Menu>INVAIZ Extension</Menu>
              </UI>
        </DispatchInfo>
        
        <DispatchInfo Host="ILST">
            <Lifecycle>
                <AutoVisible>false</AutoVisible>
                   <StartOn>
                     <Event>documentAfterActivate</Event>
                    </StartOn>
                </Lifecycle>
                <UI>
                    <Type>Custom</Type>
                    <Menu>INVAIZ Extension</Menu>
                </UI>
        </DispatchInfo>

        <DispatchInfo Host="AEFT">
          <Lifecycle>
           <AutoVisible>false</AutoVisible>
            <StartOn>
             <Event>com.adobe.csxs.events.ApplicationActivate</Event>
            </StartOn>
         </Lifecycle>
           <UI>
            <Type>Custom</Type>
           <Menu>INVAIZ Extension</Menu>
         </UI>
       </DispatchInfo>

 
      <DispatchInfo Host="IDSN">
        <Lifecycle>
          <AutoVisible>false</AutoVisible>
          <StartOn>
            <Event>documentAfterActivate</Event>
          </StartOn>
        </Lifecycle>
        <UI>
          <Type>Modeless</Type>
          <Menu>INVAIZ Extension</Menu>
        </UI>
      </DispatchInfo>

      <DispatchInfo Host="PPRO">
        <Lifecycle>
          <AutoVisible>false</AutoVisible>
          <StartOn>
            <Event>com.adobe.csxs.events.ApplicationActivate</Event>
          </StartOn>
        </Lifecycle>
        <UI>
          <Type>Custom</Type>
          <Menu>INVAIZ Extension</Menu>
        </UI>
      </DispatchInfo>

      <DispatchInfo>

        <Resources>
          <MainPath>./client/index.html</MainPath>
           <ScriptPath>./host/index.jsx</ScriptPath>
           <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
      <AutoVisible>false</AutoVisible>
          <StartOn>
            <!-- Photoshop dispatches this event on startup -->
            <Event>applicationActivate</Event> 
          </StartOn>
        </Lifecycle>
        <UI>
          <Type>Custom</Type>
          <Menu>INVAIZ Extension</Menu>
          <Geometry>
            <Size>
              <Height>30</Height>
              <Width>30</Width>
            </Size>
          </Geometry>
          <Icons />
        </UI>
      </DispatchInfo>

    </Extension>
  </DispatchInfoList>
</ExtensionManifest>